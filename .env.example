PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/foodshare

# JWT
JWT_SECRET=change_this_to_a_long_random_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mail (Resend). Laisser RESEND_API_KEY vide pour logger les codes en console (dev).
RESEND_API_KEY=
MAIL_FROM=FoodShare <onboarding@resend.dev>
VERIFY_CODE_TTL_MIN=15
RESET_CODE_TTL_MIN=15
